# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_YOUR_SECRET_KEY_RUN_python_-c_import_secrets_print_secrets.token_urlsafe_50
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=bot_db
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# ── Cache (set REDIS_URL to enable Redis; leave blank for local dev) ──────────
REDIS_URL=

# ── AI Providers ──────────────────────────────────────────────────────────────
# PRIMARY: Groq is used for all main SEO analysis + content suggestions
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY

# OPTIONAL: Only needed for /api/generator/ article generation endpoints
# If blank, those endpoints return "API key not configured"
OPENAI_API_KEY=

# ── SERP ──────────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=REPLACE_WITH_YOUR_SERPAPI_KEY
